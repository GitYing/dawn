<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- unless settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {%- case request.path -%}
      {%- when '/pricing' -%}
        {%- assign page_description = 'Snowball pricing: one simple fee of $500 AUD a week, everything included. Your first week is free and you can cancel anytime.' -%}
      {%- when '/snowball' -%}
        {%- assign page_description = 'Snowball helps Australian service businesses turn more visitors into leads with a sharper website, clearer offer and faster path to enquiry.' -%}
      {%- when '/services/vibe-code-rescue' -%}
        {%- assign page_description = 'Vibe Code Rescue fixes broken AI-built apps, stabilises the codebase and gets your product back to a usable launch path.' -%}
      {%- when '/blog/fix-broken-cursor-app' -%}
        {%- assign page_description = 'Fix a broken Cursor app with practical steps to diagnose errors, recover your code and get your AI-built project moving again.' -%}
      {%- when '/services/shopify' -%}
        {%- assign page_description = 'Launch or improve a Shopify store that feels premium, loads fast and makes it easier for customers to buy.' -%}
      {%- when '/services/saas' -%}
        {%- assign page_description = 'Build a clear, conversion-focused SaaS website that explains your product, earns trust and turns trial-ready visitors into leads.' -%}
    {%- endcase -%}

    <title>{{ shop.name }}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags', page_description: page_description %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {% style %}
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}

      :root {
        --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-style: {{ settings.type_body_font.style }};
        --font-body-weight: {{ settings.type_body_font.weight }};

        --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-heading-style: {{ settings.type_header_font.style }};
        --font-heading-weight: {{ settings.type_header_font.weight }};

        --color-base-text: {{ settings.colors_text }};
        --color-base-text-rgb: {{ settings.colors_text | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-background-1: {{ settings.colors_background_1 }};
        --color-base-background-1-rgb: {{ settings.colors_background_1 | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-background-2: {{ settings.colors_background_2 }};
        --color-base-background-2-rgb: {{ settings.colors_background_2 | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-solid-button-labels: {{ settings.colors_solid_button_labels }};
        --color-base-solid-button-labels-rgb: {{ settings.colors_solid_button_labels | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-outline-button-labels: {{ settings.colors_outline_button_labels }};
        --color-base-outline-button-labels-rgb: {{ settings.colors_outline_button_labels | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-accent-1: {{ settings.colors_accent_1 }};
        --color-base-accent-1-rgb: {{ settings.colors_accent_1 | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-base-accent-2: {{ settings.colors_accent_2 }};
        --color-base-accent-2-rgb: {{ settings.colors_accent_2 | color_to_rgb | remove: 'rgb(' | remove: ')' }};

        --color-base-text-opacity-10-percent: {{ settings.colors_text | color_mix: settings.colors_background_1, 10 }};
        --color-base-text-opacity-20-percent: {{ settings.colors_text | color_mix: settings.colors_background_1, 20 }};
        --color-base-text-opacity-55-percent: {{ settings.colors_text | color_mix: settings.colors_background_1, 55 }};
        --color-base-text-opacity-85-percent: {{ settings.colors_text | color_mix: settings.colors_background_1, 85 }};
        --color-base-accent-1-opacity-10-percent: {{ settings.colors_accent_1 | color_mix: settings.colors_background_1, 10 }};
        --color-base-accent-2-opacity-10-percent: {{ settings.colors_accent_2 | color_mix: settings.colors_background_1, 10 }};
      }

      *,
      *::before,
      *::after {
        box-sizing: inherit;
      }

      html {
        box-sizing: border-box;
        font-size: 62.5%;
        height: 100%;
      }

      body {
        display: grid;
        grid-template-rows: auto auto 1fr auto;
        grid-template-columns: 100%;
        min-height: 100%;
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: 0.06rem;
        line-height: 1.8;
        font-family: var(--font-body-family);
        font-style: var(--font-body-style);
        font-weight: var(--font-body-weight);
      }

      @media screen and (min-width: 750px) {
        body {
          font-size: 1.6rem;
        }
      }
    {% endstyle %}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body>
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}

      {%- case request.path -%}
        {%- when '/work/casa' -%}
          <section class="cs-proof">
            <h2>// The brief</h2>
            <p>CASA came to Sonder after seeing the RMIT engagement, needing an enterprise-grade Shopify build that could turn a polished set of Figma designs into a live store without losing fidelity. The brief was twofold: tighten the internal process that surrounded each new product launch, and lift the store's conversion rate above what their previous setup could deliver.</p>
            <h2>// What we delivered</h2>
            <ul>
              <li>A full Shopify Plus build taken from CASA's existing Figma designs to a production-ready store.</li>
              <li>A structured product launch workflow that reduced manual steps for the internal team.</li>
              <li>Conversion-focused templates, navigation and checkout flows built to the standard of a Shopify Plus build.</li>
              <li>Handover and documentation to let the CASA team run the store day to day.</li>
            </ul>
            <h2>// The outcome</h2>
            <p>The new store replaced a slower, more manual setup with a build that matched the enterprise standard CASA expected from the RMIT work, giving the team a cleaner process and a stronger foundation for conversion growth.</p>
          </section>
        {%- when '/work/razorback-4x4' -%}
          <section class="cs-proof">
            <h2>// The brief</h2>
            <p>Razorback 4x4 makes serious off-road gear, cut and sewn in Australia, and needed a store that could keep up with a brand growing faster than its previous platform could handle. The brief was for a full custom Shopify build that matched the toughness of the product and could scale with demand.</p>
            <h2>// What we delivered</h2>
            <ul>
              <li>A full custom Shopify build designed and built from the ground up for the Razorback 4x4 brand.</li>
              <li>A product and category structure built for a heavy-duty accessory catalogue.</li>
              <li>Performance and checkout work tuned for a high-demand, fast-moving store.</li>
              <li>A foundation that could scale as the brand grew.</li>
            </ul>
            <h2>// The outcome</h2>
            <p>Within twelve months Razorback 4x4 was named one of Australia's fastest growing businesses, and the custom build scaled right alongside that growth rather than holding it back.</p>
          </section>
        {%- when '/work/gather' -%}
          <section class="cs-proof">
            <h2>// The brief</h2>
            <p>Gather, which began life as Klavx, came out of a problem Sonder kept meeting with clients: a proper integration between Lightspeed Retail X and Klaviyo for Shopify merchants. The brief was to build a dedicated product for that one problem rather than bolt a generic feature onto the side.</p>
            <h2>// What we delivered</h2>
            <ul>
              <li>A focused integration connecting Lightspeed Retail X to Klaviyo, built specifically for Shopify merchants.</li>
              <li>A dedicated product rather than a tacked-on feature, owned end to end.</li>
              <li>The foundations for what grew into a SaaS business of its own.</li>
            </ul>
            <h2>// The outcome</h2>
            <p>Gather grew into a focused Lightspeed and Klaviyo integration trusted by merchants around the world, and a SaaS business in its own right.</p>
          </section>
        {%- when '/work/aeroberm' -%}
          <section class="cs-proof">
            <h2>// The brief</h2>
            <p>Aeroberm, an award-winning aviation and advanced air mobility venture led by Clem Newton-Brown (sister venture to Skyportz), needed a credible online presence fast, ahead of media coverage. The brief was for a custom build rather than an off-the-shelf platform, covering the technology, markets, investor and contact stories.</p>
            <h2>// What we delivered</h2>
            <ul>
              <li>A fast, modern custom website built rather than assembled from a template.</li>
              <li>Pages covering technology, markets, investor and contact stories.</li>
              <li>A build designed to be iterated as the company moved.</li>
              <li>A foundation light enough to launch quickly and strong enough to grow with.</li>
            </ul>
            <h2>// The outcome</h2>
            <p>Within three weeks of launch, and off the back of media coverage with no paid promotion, qualified visitors were already finding their way to the contact and investor pages.</p>
          </section>
        {%- when '/work/applied-ev' -%}
          <section class="cs-proof">
            <h2>// The brief</h2>
            <p>Applied EV asked Sonder to help them launch at CES very early in the company's life, with one high-stakes week in Las Vegas. The brief spanned web, brand and video, and called for everything to be engineered from scratch for a single launch moment.</p>
            <h2>// What we delivered</h2>
            <ul>
              <li>A world-class website designed and built for the launch.</li>
              <li>Editing of the launch video.</li>
              <li>On-the-ground support in Las Vegas, from setting up the stand to talking with potential customers and partners.</li>
              <li>A custom build engineered for one high-stakes week, the way every custom build is approached.</li>
            </ul>
            <h2>// The outcome</h2>
            <p>The launch landed and played its part in the millions of dollars of funding and partnerships that followed, giving Applied EV a credible platform at the moment it mattered most.</p>
          </section>
        {%- when '/pricing' -%}
          <section class="pricing-page">
            <h1>Pricing</h1>
            <p>One simple fee: $500 AUD a week, everything included. Your first week is free and you can cancel anytime.</p>
            <p><a href="https://buy.stripe.com/eVqaEZfM8aXPa4M4Fte3e0h">Start your free week &rarr;</a></p>
            <h2>// Everything included</h2>
            <ul>
              <li>Watched every hour: errors, speed, search and every visitor.</li>
              <li>Fixes what breaks, before it costs you.</li>
              <li>Grows what works, week after week.</li>
              <li>A human approves every change before it ships.</li>
              <li>Live dashboard, every fix receipted and reversible.</li>
            </ul>
            <h2>// First week free</h2>
            <p>Try Snowball on your own site for a week at no cost. If you stay, the fee stays flat: $500 AUD a week, no lock-in, cancel anytime.</p>
            <h2>// Questions</h2>
            <p>See <a href="/snowball">how Snowball works</a>, get a <a href="/dead-or-alive">free dead-or-alive scan</a>, or <a href="/contact">talk to the team</a>.</p>
          </section>
      {%- endcase -%}
    </main>

    {% section 'footer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    <script>
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}'
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t }}`
      }

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      }
    </script>

    <script src="{{ 'slider.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'variants.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
